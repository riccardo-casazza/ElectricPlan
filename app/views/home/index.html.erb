<% content_for :title, "ElectricPlan" %>

<h1>ElectricPlan</h1>

<div style="margin-top: 2rem;">
  <h2>Management Sections</h2>

  <div style="margin: 1rem 0;">
    <h3>
      <%= heroicon "home", variant: :outline, options: { style: "width: 24px; height: 24px; display: inline-block; vertical-align: middle; margin-right: 0.5rem;" } %>
      <%= link_to "Dwellings", dwellings_path %>
    </h3>
  </div>

  <div style="margin: 1rem 0;">
    <h3>
      <%= heroicon "rectangle-stack", variant: :outline, options: { style: "width: 24px; height: 24px; display: inline-block; vertical-align: middle; margin-right: 0.5rem;" } %>
      <%= link_to "Electrical Panels", electrical_panels_path %>

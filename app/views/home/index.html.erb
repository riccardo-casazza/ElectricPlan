  </div>

  <h2>Configurations</h2>

  <div style="margin: 1rem 0;">
    <h3>
      <%= heroicon "cog-6-tooth", variant: :outline, options: { style: "width: 24px; height: 24px; display: inline-block; vertical-align: middle; margin-right: 0.5rem;" } %>
      <%= link_to "Configuration", configuration_index_path %>
    </h3>
  </div>

</div>
